import numpy as np
import matplotlib.pyplot as plt

from src.config import FieldParameters
from src.coil_geometry import Coil
from src.simulation import simular_protocolo
from src.metaestructura import NodoMETFI, FlujoMETFI
from src.metfi_engine import respuesta_a_niveles, calcular_invariantes
from src.sigma_t import operador_regenerativo, operador_analgesico
from src.nexus_eeg import respuesta_a_eeg
from src.orion_interface import construir_estado_orion
params = FieldParameters(
    frecuencia_hz=1000.0,
    intensidad_mt=1.0,
    duracion_min=5.0,
    forma_onda="sinusoidal"
)

coil = Coil(
    radio_m=0.05,
    vueltas=200,
    longitud_m=0.15
)

params, coil
t, campo, respuesta = simular_protocolo(params, coil)

print("Respuesta tisular estimada:")
print(respuesta)
plt.figure(figsize=(12,4))
plt.plot(t, campo, color="royalblue")
plt.title("Campo EM generado por la bobina (conceptual)")
plt.xlabel("Tiempo (s)")
plt.ylabel("Campo (T)")
plt.grid(True)
plt.show()
nodos, flujos = respuesta_a_niveles(respuesta)

print("Nodos METFI:")
for n in nodos:
    print(n)

print("\nFlujos METFI:")
for f in flujos:
    print(f)
invariantes = calcular_invariantes(respuesta)

print("Invariantes METFI:")
for inv in invariantes:
    print(inv)
op_reg = operador_regenerativo()
op_an = operador_analgesico()

respuesta_reg = op_reg.aplicar_a_respuesta(respuesta)
respuesta_an = op_an.aplicar_a_respuesta(respuesta)

print("Respuesta con operador regenerativo:")
print(respuesta_reg)

print("\nRespuesta con operador analgésico:")
print(respuesta_an)
estado_eeg = respuesta_a_eeg(respuesta)

print("Estado EEG conceptual:")
print(estado_eeg)
estado_orion = construir_estado_orion(nodos, flujos, estado_eeg)

print("Estado ORION‑AGI:")
print(estado_orion)
plt.figure(figsize=(10,5))

magnitudes = [f.magnitud for f in flujos]
labels = [f"{f.origen.nombre} → {f.destino.nombre}" for f in flujos]

plt.bar(labels, magnitudes, color=["darkcyan", "darkorange"])
plt.title("Flujos METFI derivados del estímulo EM")
plt.ylabel("Magnitud conceptual")
plt.grid(True, axis="y")
plt.show()
ritmos = ["delta", "theta", "alpha", "beta", "gamma"]
valores = [
    estado_eeg.delta,
    estado_eeg.theta,
    estado_eeg.alpha,
    estado_eeg.beta,
    estado_eeg.gamma
]

plt.figure(figsize=(10,5))
plt.bar(ritmos, valores, color="mediumpurple")
plt.title("Modulación conceptual de ritmos EEG")
plt.ylabel("Intensidad relativa")
plt.grid(True, axis="y")
plt.show()
def pipeline_completo(params, coil):
    t, campo, respuesta = simular_protocolo(params, coil)
    nodos, flujos = respuesta_a_niveles(respuesta)
    invariantes = calcular_invariantes(respuesta)
    eeg = respuesta_a_eeg(respuesta)
    estado_orion = construir_estado_orion(nodos, flujos, eeg)
    return {
        "respuesta": respuesta,
        "nodos": nodos,
        "flujos": flujos,
        "invariantes": invariantes,
        "eeg": eeg,
        "orion": estado_orion
    }

resultado = pipeline_completo(params, coil)
resultado
